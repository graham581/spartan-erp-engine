' ---------------------------------------------------------------------
' OUT-OF-SLICE MASTERS  (referenced by in-scope FKs; build later)
' ---------------------------------------------------------------------
class PriceList      <<external>> { + price_list_name : Data }
class CustomerGroup  <<external>> { + customer_group_name : Data }
class Territory      <<external>> { + territory_name : Data }
class ItemGroup      <<external>> { + item_group_name : Data }
class Warehouse      <<external>> { + warehouse_name : Data }
class Country        <<external>> { + country_name : Data }

' ---------------------------------------------------------------------
' INHERITANCE  (which runtime base each doctype gets)
' ---------------------------------------------------------------------
Document            <|-- Currency
Document            <|-- UOM
Document            <|-- Company
Document            <|-- Customer
Document            <|-- Item
SubmittableDocument <|-- SalesOrder
ChildDocument       <|-- SalesOrderItem

' ---------------------------------------------------------------------
' DATA RELATIONSHIPS  (Link = association, Table = composition)
' ---------------------------------------------------------------------
SalesOrder "1" *-- "1..*" SalesOrderItem : items (Table)

SalesOrder --> Customer   : customer
SalesOrder --> Company    : company
SalesOrder --> Currency   : currency
SalesOrder --> PriceList  : selling_price_list
SalesOrder ..> SalesOrder : amended_from

SalesOrderItem --> Item      : item_code
SalesOrderItem --> UOM       : uom
SalesOrderItem --> Warehouse : warehouse

Item     --> UOM           : stock_uom
Item     --> ItemGroup     : item_group
Customer --> Currency      : default_currency
Customer --> PriceList     : default_price_list
Customer --> CustomerGroup : customer_group
Customer --> Territory     : territory
Company  --> Currency      : default_currency
Company  --> Country       : country
Company  ..> Company       : parent_company

@enduml
