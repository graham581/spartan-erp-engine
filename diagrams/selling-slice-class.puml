  + naming_series : Select[SAL-ORD-.YYYY.-] *
  + customer : Link(Customer) *
  + customer_name : Data
  + order_type : Select[Sales/Maintenance/Shopping Cart] *
  + company : Link(Company) *
  + transaction_date : Date *
  + delivery_date : Date
  + currency : Link(Currency) *
  + conversion_rate : Float *
  + selling_price_list : Link(PriceList) *
  + status : Select[Draft/On Hold/To Deliver and Bill/...] *
  + total_qty : Float
  + total : Currency
  + net_total : Currency
  + grand_total : Currency
  + rounded_total : Currency
  + per_delivered : Percent
  + per_billed : Percent
  + amended_from : Link(SalesOrder)
}
note bottom of SalesOrder
  SOURCE: selling/doctype/sales_order/sales_order.json
  ERPNext fields: 112  |  is_submittable: 1  |  autoname: naming_series: (SAL-ORD-.YYYY.-)
